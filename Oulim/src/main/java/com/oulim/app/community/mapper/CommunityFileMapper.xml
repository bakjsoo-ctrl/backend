<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="communityFile">

    <!-- 게시글 이미지 추가 -->
    <insert id="insertImage" parameterType="PostImageDTO">
        INSERT INTO tbl_post_image
        (
            post_no,
            post_img_system_name,
            post_img_origin_name
        )
        VALUES
        (
            #{postNo},
            #{postImgSystemName},
            #{postImgOriginName}
        )
    </insert>

    <!-- 파일 조회 -->
    <select id="selectImage" parameterType="int" resultType="PostImageDTO">
        SELECT
            post_img_system_name,
            post_img_origin_name,
            post_no
        FROM tbl_post_image
        WHERE post_no = #{postNo}
    </select>

    <!-- 파일 삭제 -->
    <delete id="deleteImage" parameterType="int">
        DELETE FROM tbl_post_image
        WHERE post_no = #{postNo}
    </delete>

</mapper>